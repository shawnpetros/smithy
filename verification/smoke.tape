# PER-218 smoke tape: proves vhs tooling works end-to-end
Output verification/smoke.gif

Set FontSize 14
Set Width 1200
Set Height 600
Set Shell "bash"

Type "echo 'smithy tui-verify: smoke test'"
Enter
Sleep 500ms
Type "echo 'PER-218: VHS tooling verified'"
Enter
Sleep 500ms
Type "vhs --version"
Enter
Sleep 1s
